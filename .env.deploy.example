# ============================================================
# Deployment credentials for Secondary Brain (Cloudflare + GitHub)
# Copy this file to ".env.deploy" and fill in real values.
# .env.deploy is gitignored — NEVER commit it.
# ============================================================

# --- Cloudflare ---
# API token. Create at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions:
#   Account > Cloudflare Pages: Edit
#   Account > Workers Scripts: Edit
#   Zone   > Workers Routes: Edit
#   Account > Account Settings: Read
#   Zone   > Zone: Read   (zone: aetherahealthcare.com)
CLOUDFLARE_API_TOKEN=

# Account ID — Cloudflare dashboard right sidebar, or run `wrangler whoami`
CLOUDFLARE_ACCOUNT_ID=

# --- GitHub ---
# Personal access token (classic or fine-grained with "repo" scope).
# Only needed for local CLI pushes; GitHub Actions injects its own GITHUB_TOKEN.
GITHUB_TOKEN=

# --- Worker origin Access service token ---
# These authenticate the Worker to the locked-down tunnel origin.
# They are stored in Cloudflare via `wrangler secret put` (see CLOUDFLARE_DEPLOYMENT.md);
# keep them here for convenience / local `wrangler dev`.
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
