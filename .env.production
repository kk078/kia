# Production Environment Configuration
# Copy this file to .env and fill in your production values

# Infrastructure Services (internal Docker network)
REDIS_URL=redis://redis:6379
WEAVIATE_URL=http://weaviate:8080
FALKORDB_URL=redis://falkordb:6379
LANGFUSE_URL=http://langfuse:3000

# Langfuse Configuration
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
LANGFUSE_SECRET=CHANGE_ME_RANDOM_SECRET
LANGFUSE_SALT=CHANGE_ME_RANDOM_SALT
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# LLM Provider API Keys (REQUIRED)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=

# Application Settings
ENVIRONMENT=production
LOG_LEVEL=INFO

# Security Settings
CORS_ORIGINS=https://yourdomain.com
ENABLE_HTTPS=true
