# Infrastructure Services
REDIS_URL=redis://localhost:6379
WEAVIATE_URL=http://localhost:8081
FALKORDB_URL=redis://localhost:6380
LANGFUSE_URL=http://localhost:3000

# Langfuse API Keys (create in Langfuse UI after first login)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# LLM Provider API Keys (Commercial)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=

# Open-Source LLM Providers (Local/Self-Hosted)
# Ollama - https://ollama.ai (recommended for local development)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# llama.cpp server - https://github.com/ggerganov/llama.cpp
LLAMACPP_BASE_URL=http://localhost:8080
LLAMACPP_MODEL=local-model

# vLLM - https://github.com/vllm-project/vllm (high-throughput serving)
VLLM_BASE_URL=http://localhost:8000
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# LocalAI - https://github.com/mudler/LocalAI (OpenAI-compatible)
LOCALAI_BASE_URL=http://localhost:8080
LOCALAI_MODEL=gpt-4

# LM Studio - https://lmstudio.ai (desktop app with API)
LMSTUDIO_BASE_URL=http://localhost:1234
LMSTUDIO_MODEL=local-model

# GPT4All - https://gpt4all.io (lightweight local LLMs)
GPT4ALL_BASE_URL=http://localhost:4891
GPT4ALL_MODEL=mistral-7b-instruct

# bitnet.cpp - https://github.com/microsoft/BitNet (1-bit LLMs)
BITNET_BASE_URL=http://localhost:8080
BITNET_MODEL=bitnet-model

# Default open-source provider (used when no commercial API keys are set)
DEFAULT_OSS_PROVIDER=ollama
DEFAULT_OSS_MODEL=llama3.1

# n8n
N8N_URL=http://localhost:5678
N8N_API_KEY=

# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO

# API Security
# Set a key to require `Authorization: Bearer <key>` (or X-API-Key) on every
# request. Empty = auth off (fine for localhost-only native mode; REQUIRED if
# the API is exposed through a tunnel). /health and /metrics stay open.
KIA_API_KEY=
# Per-client requests/minute (sliding window). 0 disables rate limiting.
RATE_LIMIT_PER_MINUTE=120

# Gateway Settings
GATEWAY_PORT=5000
PYTHON_API_PORT=8000

# Host command execution (/build command) — opt-in, confirmation-gated.
# Run host_runner/runner.py on the host with the SAME token, then enable here.
# See host_runner/README.md. Leave EXEC_ENABLED=false to keep KIA hands-off your OS.
EXEC_ENABLED=false
HOST_RUNNER_URL=http://host.docker.internal:8765
HOST_RUNNER_TOKEN=
EXEC_TIMEOUT_SECONDS=300
